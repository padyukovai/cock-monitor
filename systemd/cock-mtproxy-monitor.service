[Unit]
Description=cock-monitor MTProxy collect and alerts (oneshot)
Documentation=file:///opt/cock-monitor/README.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=root
EnvironmentFile=-/etc/cock-monitor.env
Environment=PYTHONPATH=/opt/cock-monitor
WorkingDirectory=/opt/cock-monitor
ExecStart=/usr/bin/python3 /opt/cock-monitor/bin/cock-mtproxy-collect.py --env-file /etc/cock-monitor.env

[Install]
WantedBy=multi-user.target

