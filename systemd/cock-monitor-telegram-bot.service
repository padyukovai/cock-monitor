[Unit]
Description=Poll Telegram for cock-monitor bot commands (oneshot)
Documentation=file:///opt/cock-monitor/README.md
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# /status may read conntrack stats (often needs root).
User=root
EnvironmentFile=-/etc/cock-monitor.env
Environment=COCK_MONITOR_HOME=/opt/cock-monitor
WorkingDirectory=/opt/cock-monitor
ExecStart=/usr/bin/python3 -m telegram_bot --poll-once /etc/cock-monitor.env

[Install]
WantedBy=multi-user.target
