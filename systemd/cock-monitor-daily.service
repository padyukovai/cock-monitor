[Unit]
Description=cock-monitor daily metrics chart to Telegram (oneshot)
Documentation=file:///opt/cock-monitor/README.md
After=network.target

[Service]
Type=oneshot
User=root
EnvironmentFile=-/etc/cock-monitor.env
WorkingDirectory=/opt/cock-monitor
ExecStart=/usr/bin/python3 -m cock_monitor daily-chart --env-file /etc/cock-monitor.env --send-telegram
