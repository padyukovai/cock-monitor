[Unit]
Description=cock-monitor leak investigation sampler (60s enriched profile)
Documentation=file:///opt/cock-monitor/README.md
After=network.target

[Service]
Type=oneshot
User=root
EnvironmentFile=-/etc/cock-monitor.env
Environment=INCIDENT_LEAK_INVESTIGATION=1
WorkingDirectory=/opt/cock-monitor
ExecStart=/opt/cock-monitor/.venv/bin/python -m cock_monitor run incident /etc/cock-monitor.env

[Install]
WantedBy=multi-user.target
