[Unit]
Description=cock-monitor Telegram bot poll (oneshot)
Documentation=file:///opt/cock-monitor/README.md

[Service]
Type=oneshot
User=root
EnvironmentFile=-/etc/cock-monitor.env
Environment=COCK_MONITOR_HOME=/opt/cock-monitor
WorkingDirectory=/opt/cock-monitor
ExecStart=/opt/cock-monitor/.venv/bin/python -m cock_monitor.platform.telegram --poll-once /etc/cock-monitor.env

[Install]
WantedBy=multi-user.target
