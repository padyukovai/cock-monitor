[Unit]
Description=cock-monitor MTProxy daily report to Telegram (oneshot)
Documentation=file:///opt/cock-monitor/README.md
After=network.target

[Service]
Type=oneshot
User=root
EnvironmentFile=-/etc/cock-monitor.env
WorkingDirectory=/opt/cock-monitor
ExecStart=/usr/bin/python3 -m cock_monitor mtproxy-daily --env-file /etc/cock-monitor.env --hours 24 --send-telegram

