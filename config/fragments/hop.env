# Hop module (VLESS chain monitoring) — set HOP_LINKS in profile or env
HOP_STATE_DIR=/var/lib/cock-monitor
HOP_LINKS=
HOP_ERROR_LOG_PATH=/var/log/x-ui/error.log
HOP_ESTAB_WARN=5
HOP_ESTAB_CRIT=20
HOP_FIN_WAIT_WARN=20
HOP_FIN_WAIT_CRIT=50
HOP_ERROR_DELTA_WARN=3
HOP_ERROR_DELTA_CRIT=10
HOP_ALERT_ENABLE=0
HOP_ALERT_COOLDOWN_SEC=600
HOP_PROBE_ENABLE=0
HOP_PROBES=
HOP_PROBE_PARALLEL=10
HOP_PROBE_TIMEOUT_SEC=15
HOP_PROBE_SUCCESS_WARN_PCT=80
HOP_PROBE_SUCCESS_CRIT_PCT=50
