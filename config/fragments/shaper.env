# CPU shaper module
SHAPER_IFACE=ens3
SHAPER_VPN_PORTS=443,2053,37346
SHAPER_MAX_RATE_MBIT=100
SHAPER_MIN_RATE_MBIT=10
SHAPER_CPU_TARGET_PCT=70
SHAPER_STEP_DOWN_PCT=15
SHAPER_STEP_UP_PCT=5
SHAPER_MEASURE_SLEEP_SEC=2
SHAPER_TELEGRAM_ALERTS=1
SHAPER_TELEGRAM_COOLDOWN_SEC=60
SHAPER_STATE_FILE=/var/lib/cock-monitor/cpu_shaper.state
SHAPER_STATUS_FILE=/var/lib/cock-monitor/cpu_shaper.status
