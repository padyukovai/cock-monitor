# Core module — always enabled
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

WARN_PERCENT=80
CRIT_PERCENT=95
COOLDOWN_SECONDS=3600

STATE_FILE=/var/lib/cock-monitor/state
METRICS_DB=/var/lib/cock-monitor/metrics.db
METRICS_RECORD_EVERY_RUN=1
METRICS_RETENTION_DAYS=14

CHECK_CONNTRACK_FILL=1
INCLUDE_CONNTRACK_STATS_LINE=1
DRY_RUN=0

LA_ALERT_ENABLE=1
LA_WARN_THRESHOLD=1.5
LA_ALERT_COOLDOWN_SEC=600

MEM_ALERT_ENABLE=1
MEM_WARN_AVAIL_KB=150000
MEM_CRIT_AVAIL_KB=80000
MEM_ALERT_COOLDOWN_SEC=600

STATUS_WAN_IFACE=ens3
STATUS_EXTRA_UNITS=
STATUS_IP_LINK_HEAD_LINES=12

DAILY_CHART_HOURS=24

TELEGRAM_OFFSET_FILE=
MAX_UPDATES_PER_RUN=200
MAX_SECONDS_PER_RUN=20
