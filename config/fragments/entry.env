# Entry node health — VLESS accepts by inbound + TLS error.log signals
ENTRY_ACCESS_LOG_PATH=/var/log/x-ui/access.log
ENTRY_ERROR_LOG_PATH=/var/log/x-ui/error.log
ENTRY_INBOUND_TAGS=in-443-tcp,in-8443-tcp
ENTRY_PRIMARY_INBOUND=in-443-tcp
ENTRY_SECONDARY_INBOUND=in-8443-tcp
ENTRY_STATE_DIR=/var/lib/cock-monitor
ENTRY_LOG_DIR=/var/lib/cock-monitor
ENTRY_MIN_INTERVAL_SEC=60
ENTRY_ALERT_ENABLE=0
ENTRY_ALERT_COOLDOWN_SEC=600
# Accept asymmetry (TSPU selective :443 degradation): primary rate low while secondary alive.
ENTRY_ACCEPT_PRIMARY_MIN_PER_MIN=15
ENTRY_ACCEPT_SECONDARY_MIN_PER_MIN=30
ENTRY_ACCEPT_RATIO_WARN=0.25
ENTRY_ACCEPT_RATIO_CRIT=0.10
ENTRY_REQUIRE_HOP_OK=1
# xray error.log deltas per tick interval.
ENTRY_TLS_HANDSHAKE_WARN=5
ENTRY_TLS_HANDSHAKE_CRIT=20
ENTRY_IO_TIMEOUT_WARN=10
ENTRY_IO_TIMEOUT_CRIT=30
