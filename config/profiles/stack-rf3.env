ENABLED_MODULES=core,hop,incident
STATUS_WAN_IFACE=eth0
STATUS_EXTRA_UNITS=x-ui.service,xray-hop-probe.service
INCIDENT_SYSTEMD_UNITS=x-ui.service
INCIDENT_TCP_PROBE_PORTS=443 8443
INCIDENT_TCP_PROBE_LOCAL_TARGET=127.0.0.1
INCIDENT_PING_INTERNAL_TARGETS=144.31.154.44 153.75.246.28
BURST_ACCESS_LOG_PATH=/var/log/x-ui/access.log
BURST_ERROR_LOG_PATH=/var/log/x-ui/error.log
HOP_LINKS=germany:dst:144.31.154.44:10089,usa:dst:153.75.246.28:10090
HOP_ERROR_LOG_PATH=/var/log/x-ui/error.log
HOP_ESTAB_WARN=0
HOP_ESTAB_CRIT=200
HOP_FIN_WAIT_WARN=20
HOP_FIN_WAIT_CRIT=50
HOP_ERROR_DELTA_WARN=3
HOP_ERROR_DELTA_CRIT=10
HOP_ALERT_COOLDOWN_SEC=1800
HOP_ALERT_ENABLE=1
HOP_PROBE_ENABLE=0
HOP_PROBES=germany:socks5h://127.0.0.1:10891:https://api.ipify.org?format=json:144.31.154.44,usa:socks5h://127.0.0.1:10892:https://api.ipify.org?format=json:153.75.246.28
TELEGRAM_PROXY_URL=socks5h://127.0.0.1:10891
POST_INSTALL_SCRIPTS=install/rf3/setup-hop-probe.sh
PREFLIGHT_SYSTEMD_UNITS=xray-hop-probe.service
PREFLIGHT_TCP_PORTS=10891,10892
