# Copy to e.g. /etc/cock-monitor.env and chmod 600. Do not commit real secrets.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: last getUpdates offset for the timer-driven command bot (default: next to STATE_FILE).
# TELEGRAM_OFFSET_FILE=/var/lib/cock-monitor/telegram_offset

# Fill ratio: alert when count/max reaches these percents (integers 1–100).
WARN_PERCENT=80
CRIT_PERCENT=95

# Minimum seconds between repeat alerts of the same fill severity (unless escalating warning→critical).
COOLDOWN_SECONDS=3600

# Persist cooldown / last severity (directory created manually or by install docs).
STATE_FILE=/var/lib/cock-monitor/state

# 1 = run fill check from /proc (default if unset).
CHECK_CONNTRACK_FILL=1

# Optional: append one line from `conntrack -S` to fill alerts when binary exists (no extra alerts).
INCLUDE_CONNTRACK_STATS_LINE=1

# Dry-run: print Telegram payload to stdout, do not call API (token/chat not required).
DRY_RUN=0

# --- Optional stats alerts (conntrack -S counters, summed across CPUs) ---
# 1 = evaluate thresholds below (requires conntrack tool and usually root/CAP_NET_ADMIN).
ALERT_ON_STATS=0
# Alert if cumulative counter is >= value (0 = disabled for that metric). Values are since kernel boot/counter reset.
STATS_DROP_MIN=0
STATS_INSERT_FAILED_MIN=0
# Cooldown for any STATS telegram (cumulative and/or delta); defaults to COOLDOWN_SECONDS if unset.
# STATS_COOLDOWN_SECONDS=3600
# Append host context (load, mem, TCP sockstat, shaper) to STATS alerts; shaper line uses SHAPER_STATUS_FILE ts= if fresher than N min (0 = ignore age).
# STATS_ALERT_SHAPER_MAX_AGE_MIN=15

# --- SQLite metrics history (requires sqlite3 CLI on PATH) ---
# Written by check-conntrack.sh when METRICS_RECORD_EVERY_RUN=1 and/or ALERT_ON_STATS_DELTA=1.
# Same DB also has table host_samples (load, mem, sockstat, shaper, tc qdisc) keyed by same ts as conntrack_samples; see README.md.
METRICS_DB=/var/lib/cock-monitor/metrics.db
METRICS_RECORD_EVERY_RUN=1
# 1 = store first line of `tc qdisc show dev $SHAPER_IFACE root` in host_samples (0 = skip).
# METRICS_COLLECT_TC_QDISC=1
# Skip INSERT if last sample is newer than this many seconds (0 = always insert when recording).
# METRICS_RECORD_MIN_INTERVAL_SEC=0
# Delete samples older than this many days (0 = disable time-based pruning).
METRICS_RETENTION_DAYS=14
# Keep at most this many newest rows; 0 = no row-count limit.
# METRICS_MAX_ROWS=0

# --- Delta / rate stats alerts (vs previous row in METRICS_DB; first sample never alerts) ---
ALERT_ON_STATS_DELTA=0
# Ignore delta/rate checks unless interval between samples is at least this many seconds.
STATS_DELTA_MIN_INTERVAL_SEC=60
# Per-metric: fire if delta since last sample >= value (0 = off).
STATS_DELTA_DROP_MIN=0
STATS_DELTA_INSERT_FAILED_MIN=0
STATS_DELTA_EARLY_DROP_MIN=0
STATS_DELTA_ERROR_MIN=0
STATS_DELTA_INVALID_MIN=0
STATS_DELTA_SEARCH_RESTART_MIN=0
# Per-metric: fire if estimated rate (delta * 60 / interval_sec) >= events per minute (0 = off).
STATS_RATE_DROP_PER_MIN=0
STATS_RATE_INSERT_FAILED_PER_MIN=0
STATS_RATE_EARLY_DROP_PER_MIN=0
STATS_RATE_ERROR_PER_MIN=0
STATS_RATE_INVALID_PER_MIN=0
STATS_RATE_SEARCH_RESTART_PER_MIN=0

# --- Daily PNG report (cock-monitor-daily.timer; needs python3-matplotlib or pip matplotlib) ---
DAILY_CHART_HOURS=24

# --- 3x-ui VLESS daily traffic report ---
# 3x-ui sqlite path on host (Docker volume path in your setup).
# Resolve on the host, e.g.: docker volume inspect <name> --format '{{ .Mountpoint }}'/x-ui.db
XUI_DB_PATH=/var/lib/docker/volumes/<3x-ui-volume>/_data/x-ui.db
# Report timezone: calendar day boundaries, titles, and "since last sent" clock in subtitles.
# Use Europe/Moscow for MSK-only reporting.
VLESS_DAILY_TZ=Europe/Moscow
# Wall-clock times inside the Telegram HTML (e.g. "since last sent at …") in this TZ (default MSK).
# VLESS_TELEGRAM_DISPLAY_TZ=Europe/Moscow
# Number of top clients shown in daily report.
VLESS_DAILY_TOP_N=10
# Absolute abuse threshold, GB per day.
VLESS_ABUSE_GB=20
# Relative abuse threshold by daily share (% of total daily traffic).
VLESS_ABUSE_SHARE_PCT=40
# Ignore relative abuse threshold when total daily traffic is below this size (MB).
VLESS_DAILY_MIN_TOTAL_MB=500

# Optional: Xray access.log on the host (same inode as bind-mounted /app/access.log in 3x-ui).
# Enables unique IPv4/IPv6 counts per VLESS email in cock-vless-daily-report.py.
# VLESS_ACCESS_LOG_PATH=/opt/3x-ui/log/xray-access.log
# Optional second file when rotating logs (if not using default .1 next to primary).
# VLESS_ACCESS_LOG_PATH_PREV=/opt/3x-ui/log/xray-access.log.1
# Timezone for naive timestamps inside access.log (must match TZ of the process writing the log).
# If unset, defaults to VLESS_DAILY_TZ. For MSK-aligned IP windows and MSK log lines, run 3x-ui with TZ=Europe/Moscow
# and leave this unset (or set Europe/Moscow).
# VLESS_ACCESS_LOG_TZ=Europe/Moscow
# Separate top by (unique IPv4 + unique IPv6).
# VLESS_IP_TOP_K=3
# Max megabytes read per log file per run (head for --mode daily, tail for since-last-sent).
# VLESS_IP_PARSE_MAX_MB=256

# --- Incident sampler (frequent network/DNS/conntrack snapshots) ---
# 1 = run bin/incident-sampler.sh on each timer tick; 0 = safe no-op.
INCIDENT_SAMPLER_ENABLE=0
# JSONL output directory (one file per UTC day: incident-YYYYMMDD.jsonl).
INCIDENT_LOG_DIR=/var/lib/cock-monitor
# Persistent alert state (last severity, cooldown, DNS fail streak).
INCIDENT_STATE_FILE=/var/lib/cock-monitor/incident_sampler.state
# Space-separated ping targets.
INCIDENT_PING_TARGETS="1.1.1.1 8.8.8.8"
INCIDENT_PING_COUNT=2
INCIDENT_PING_TIMEOUT_SEC=1
INCIDENT_PING_LOSS_WARN_PCT=20
# DNS probe host and timeout (seconds).
INCIDENT_DNS_HOST=api.telegram.org
INCIDENT_DNS_TIMEOUT_SEC=2
INCIDENT_DNS_FAIL_STREAK_WARN=3
# Conntrack fill thresholds (percent).
INCIDENT_CONNTRACK_WARN_PCT=85
INCIDENT_CONNTRACK_CRIT_PCT=95
# Optional units snapshot (`systemctl is-active`).
INCIDENT_SYSTEMD_UNITS="x-ui.service"
# Telegram incident alerts (uses TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID).
INCIDENT_ALERT_ENABLE=0
INCIDENT_ALERT_COOLDOWN_SEC=300
# After recovery (WARN/CRIT -> OK), send HTML post-mortem from JSONL (needs python3).
INCIDENT_POSTMORTEM_ENABLE=1

# --- CPU-Aware WAN egress shaper (CAKE / cock-cpu-shaper) ---
SHAPER_ENABLE=0
SHAPER_IFACE=ens3
# Optional: WAN interface for `ip -s link` in cock-status / Telegram /status (RX/TX drops/errors).
# Default is SHAPER_IFACE if set, else ens3.
# STATUS_WAN_IFACE=ens3
# Max lines of `ip -s link` output in /status (8–60, default 22).
# STATUS_IP_LINK_HEAD_LINES=22
# Optional: space-separated systemd units — is-active + ActiveEnterTimestamp (compact).
# STATUS_EXTRA_UNITS="x-ui.service cock-monitor.timer"
# Comma-separated host ports published for VPN / panel (Docker DNAT).
SHAPER_VPN_PORTS=443,2053,37346
SHAPER_MAX_RATE_MBIT=100
SHAPER_MIN_RATE_MBIT=10
# Target CPU load percentage (derived from idle/iowait). Shaper limits bandwidth to stay below this.
SHAPER_CPU_TARGET_PCT=70
SHAPER_STEP_DOWN_PCT=15
SHAPER_STEP_UP_PCT=5
# Sleep interval in seconds for measuring CPU delta.
SHAPER_MEASURE_SLEEP_SEC=2
# Send telegram alerts when bandwidth changes (1 = enable, 0 = disable)
SHAPER_TELEGRAM_ALERTS=1
SHAPER_TELEGRAM_COOLDOWN_SEC=60
# SHAPER_STATE_FILE=/var/lib/cock-monitor/cpu_shaper.state
# SHAPER_STATUS_FILE=/var/lib/cock-monitor/cpu_shaper.status

# --- Load Average alert (check-conntrack.sh) ---
# 1 = alert when 1-minute load average exceeds threshold.
# On a single-core server: la1 > 1.0 means CPU queue forming, > 1.5 is sustained overload.
LA_ALERT_ENABLE=0
# la1 threshold (float). For N vCPUs, a rule of thumb is warn at N*1.0 .. N*1.5.
LA_WARN_THRESHOLD=1.5
# Minimum seconds between repeat LA alerts.
LA_ALERT_COOLDOWN_SEC=600
