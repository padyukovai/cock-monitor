# Copy to e.g. /etc/cock-monitor.env and chmod 600. Do not commit real secrets.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Fill ratio: alert when count/max reaches these percents (integers 1–100).
WARN_PERCENT=80
CRIT_PERCENT=95

# Minimum seconds between repeat alerts of the same fill severity (unless escalating warning→critical).
COOLDOWN_SECONDS=3600

# Persist cooldown / last severity (directory created manually or by install docs).
STATE_FILE=/var/lib/cock-monitor/state

# 1 = run fill check from /proc (default if unset).
CHECK_CONNTRACK_FILL=1

# Optional: append one line from `conntrack -S` to fill alerts when binary exists (no extra alerts).
INCLUDE_CONNTRACK_STATS_LINE=1

# Dry-run: print Telegram payload to stdout, do not call API (token/chat not required).
DRY_RUN=0

# --- Optional stats alerts (conntrack -S counters, summed across CPUs) ---
# 1 = evaluate thresholds below (requires conntrack tool and usually root/CAP_NET_ADMIN).
ALERT_ON_STATS=0
# Alert if cumulative counter is >= value (0 = disabled for that metric).
STATS_DROP_MIN=0
STATS_INSERT_FAILED_MIN=0
# Cooldown for stats alerts (defaults to COOLDOWN_SECONDS if unset).
# STATS_COOLDOWN_SECONDS=3600
