# Copy to e.g. /etc/cock-monitor.env and chmod 600. Do not commit real secrets.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional: last getUpdates offset for the timer-driven command bot (default: next to STATE_FILE).
# TELEGRAM_OFFSET_FILE=/var/lib/cock-monitor/telegram_offset

# Fill ratio: alert when count/max reaches these percents (integers 1–100).
WARN_PERCENT=80
CRIT_PERCENT=95

# Minimum seconds between repeat alerts of the same fill severity (unless escalating warning→critical).
COOLDOWN_SECONDS=3600

# Persist cooldown / last severity (directory created manually or by install docs).
STATE_FILE=/var/lib/cock-monitor/state

# 1 = run fill check from /proc (default if unset).
CHECK_CONNTRACK_FILL=1

# Optional: append one line from `conntrack -S` to fill alerts when binary exists (no extra alerts).
INCLUDE_CONNTRACK_STATS_LINE=1

# Dry-run: print Telegram payload to stdout, do not call API (token/chat not required).
DRY_RUN=0

# --- Optional stats alerts (conntrack -S counters, summed across CPUs) ---
# 1 = evaluate thresholds below (requires conntrack tool and usually root/CAP_NET_ADMIN).
ALERT_ON_STATS=0
# Alert if cumulative counter is >= value (0 = disabled for that metric). Values are since kernel boot/counter reset.
STATS_DROP_MIN=0
STATS_INSERT_FAILED_MIN=0
# Cooldown for any STATS telegram (cumulative and/or delta); defaults to COOLDOWN_SECONDS if unset.
# STATS_COOLDOWN_SECONDS=3600

# --- SQLite metrics history (requires sqlite3 CLI on PATH) ---
# Written by check-conntrack.sh when METRICS_RECORD_EVERY_RUN=1 and/or ALERT_ON_STATS_DELTA=1.
METRICS_DB=/var/lib/cock-monitor/metrics.db
METRICS_RECORD_EVERY_RUN=1
# Skip INSERT if last sample is newer than this many seconds (0 = always insert when recording).
# METRICS_RECORD_MIN_INTERVAL_SEC=0
# Delete samples older than this many days (0 = disable time-based pruning).
METRICS_RETENTION_DAYS=14
# Keep at most this many newest rows; 0 = no row-count limit.
# METRICS_MAX_ROWS=0

# --- Delta / rate stats alerts (vs previous row in METRICS_DB; first sample never alerts) ---
ALERT_ON_STATS_DELTA=0
# Ignore delta/rate checks unless interval between samples is at least this many seconds.
STATS_DELTA_MIN_INTERVAL_SEC=60
# Per-metric: fire if delta since last sample >= value (0 = off).
STATS_DELTA_DROP_MIN=0
STATS_DELTA_INSERT_FAILED_MIN=0
STATS_DELTA_EARLY_DROP_MIN=0
STATS_DELTA_ERROR_MIN=0
STATS_DELTA_INVALID_MIN=0
STATS_DELTA_SEARCH_RESTART_MIN=0
# Per-metric: fire if estimated rate (delta * 60 / interval_sec) >= events per minute (0 = off).
STATS_RATE_DROP_PER_MIN=0
STATS_RATE_INSERT_FAILED_PER_MIN=0
STATS_RATE_EARLY_DROP_PER_MIN=0
STATS_RATE_ERROR_PER_MIN=0
STATS_RATE_INVALID_PER_MIN=0
STATS_RATE_SEARCH_RESTART_PER_MIN=0

# --- Daily PNG report (cock-monitor-daily.timer; needs python3-matplotlib or pip matplotlib) ---
DAILY_CHART_HOURS=24
