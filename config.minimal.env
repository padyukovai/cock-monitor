# Minimal starter config for conntrack alerts only.
# Copy to /etc/cock-monitor.env and fill TELEGRAM_* values.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Core conntrack thresholds.
WARN_PERCENT=80
CRIT_PERCENT=95
COOLDOWN_SECONDS=3600

# Runtime files.
STATE_FILE=/var/lib/cock-monitor/state
METRICS_DB=/var/lib/cock-monitor/metrics.db
METRICS_RECORD_EVERY_RUN=1
METRICS_RETENTION_DAYS=14

# Safe defaults.
CHECK_CONNTRACK_FILL=1
INCLUDE_CONNTRACK_STATS_LINE=1
DRY_RUN=0

# Disable optional modules by default.
MTPROXY_ENABLE=0
INCIDENT_SAMPLER_ENABLE=0
SHAPER_ENABLE=0
LA_ALERT_ENABLE=0
